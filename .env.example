# =============================================================================
# WiseFood UI — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env
#
# VITE_* and NUXT_PUBLIC_* values are exposed to the browser — never put
# secrets in them. In the Docker image these are re-read at container start
# and injected as window.__RUNTIME_CONFIG__ (see docker-entrypoint.sh), so the
# same build can be promoted across environments without rebuilding.
# =============================================================================

# --- Authentication (Keycloak) ----------------------------------------------
VITE_KEYCLOAK_URL=https://auth.wisefood-project.eu/
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=wisefood-ui
# Set to "true" to log Keycloak/auth-store debug output to the console.
VITE_KEYCLOAK_DEBUG=false

# --- WiseFood backends -------------------------------------------------------
# Data Catalog API.
VITE_WISEFOOD_API_URL=https://demo.wisefood-project.eu/dc/api
# REST API (v1).
VITE_WISEFOOD_REST_API_URL=https://demo.wisefood-project.eu/rest/api/v1

# --- Recipe Wrangler ---------------------------------------------------------
VITE_RECIPE_WRANGLER_API_URL=http://127.0.0.1:8001/api/v1
# Backend selection: auto | local | rest
VITE_RECIPE_WRANGLER_MODE=auto

# --- Flows.js (interactive product walkthroughs) -----------------------------
# Organization id from the Flows dashboard (public client-side identifier, not
# a secret). When empty, Flows is disabled and the app behaves normally.
VITE_FLOWS_ORG_ID=dc7f41f1-e34d-40f4-afe0-59189ebc62c2
# Flows environment key (Settings > Environments). Defaults to "production".
VITE_FLOWS_ENVIRONMENT=production

# --- Error reporting (Sentry) ------------------------------------------------
# Public DSN (browser-exposed). Leave empty to disable Sentry.
NUXT_PUBLIC_SENTRY_DSN=
# Toggle Sentry explicitly: "true" / "false". When unset, it is enabled for
# every command except `dev`.
SENTRY_ENABLED=
# Source-map upload (build-time only). SENTRY_AUTH_TOKEN is a SECRET — keep it
# out of version control and CI logs.
SENTRY_ORG=wisefood
SENTRY_PROJECT=wisefood
SENTRY_AUTH_TOKEN=

# --- Application -------------------------------------------------------------
# Base URL / context path the app is served under (e.g. "/app"). Defaults to "/".
NUXT_APP_BASE_URL=/
# Set to "true" to enable Nuxt Devtools.
NUXT_DEVTOOLS=false
